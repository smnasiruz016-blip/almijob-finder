generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PRO
}

enum RemoteMode {
  REMOTE
  HYBRID
  ONSITE
  FLEXIBLE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  TEMPORARY
}

enum AlertFrequency {
  DAILY
  WEEKLY
}

enum CompanyUserRole {
  OWNER
  ADMIN
  RECRUITER
}

enum VacancyStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  passwordHash  String
  role          UserRole        @default(USER)
  subscriptionTier SubscriptionTier @default(FREE)
  sessions      Session[]
  resumes       Resume[]
  searches      JobSearch[]
  searchHistory SearchHistory[]
  savedJobs     SavedJob[]
  savedSearches SavedSearch[]
  companyMemberships CompanyUser[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Resume {
  id                String   @id @default(cuid())
  userId            String
  originalFilename  String?
  storagePath       String?
  mimeType          String?
  extractedText     String?  @db.Text
  parsedName        String?
  parsedEmail       String?
  parsedPhone       String?
  skills            String[]
  experienceKeywords String[]
  educationKeywords String[]
  preferredRoles    String[]
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
}

model JobSearch {
  id             String           @id @default(cuid())
  userId         String
  desiredTitle   String
  keyword        String?
  company        String?
  country        String
  state          String?
  city           String?
  remoteMode     RemoteMode?
  employmentType EmploymentType?
  postedWithinDays Int?
  salaryMin      Int?
  salaryMax      Int?
  latestResults  Json?
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  history        SearchHistory[]
  createdAt      DateTime         @default(now())
}

model SearchHistory {
  id           String    @id @default(cuid())
  userId       String
  searchId     String?
  snapshot     Json
  resultsCount Int
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  search       JobSearch? @relation(fields: [searchId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
}

model SavedJob {
  id            String   @id @default(cuid())
  userId        String
  externalJobId String
  source        String
  title         String
  company       String
  location      String
  applyUrl      String
  payload       Json
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([userId, externalJobId, source])
}

model SavedSearch {
  id             String         @id @default(cuid())
  userId         String
  name           String
  querySnapshot  Json
  alertsEnabled  Boolean        @default(false)
  alertFrequency AlertFrequency @default(DAILY)
  lastAlertedAt  DateTime?
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
}

model JobResultCache {
  id            String   @id @default(cuid())
  externalJobId String
  source        String
  title         String
  company       String
  location      String
  postedDate    DateTime?
  payload       Json
  createdAt     DateTime @default(now())

  @@unique([externalJobId, source])
}

model Company {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  website     String?
  logoUrl     String?
  description String?       @db.Text
  country     String
  state       String?
  city        String?
  verified    Boolean       @default(false)
  users       CompanyUser[]
  vacancies   Vacancy[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model CompanyUser {
  id        String          @id @default(cuid())
  companyId String
  userId    String          @unique
  role      CompanyUserRole @default(RECRUITER)
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([companyId, userId])
}

model Vacancy {
  id             String           @id @default(cuid())
  companyId      String
  title          String
  description    String           @db.Text
  country        String
  state          String?
  city           String?
  remoteMode     RemoteMode?
  employmentType EmploymentType?
  salaryMin      Int?
  salaryMax      Int?
  applyUrl       String?
  status         VacancyStatus    @default(DRAFT)
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model JobSourceDirectory {
  id              String   @id @default(cuid())
  region          String
  country         String
  website         String
  url             String
  category        String
  notes           String?  @db.Text
  sourcePriority  Int      @default(100)
  hasApi          Boolean  @default(false)
  isAggregator    Boolean  @default(false)
  isEmployerBoard Boolean  @default(false)
  isTrusted       Boolean  @default(true)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([country, website])
  @@index([country, active, sourcePriority])
}
